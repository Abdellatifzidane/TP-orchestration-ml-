FROM apache/airflow:2.10.5-python3.11

# On evite mlflow 3.x (chaine de deps fastmcp/pydocket coute des minutes de
# resolution pip a chaque demarrage). 2.x est largement suffisant pour ce TP.
RUN pip install --no-cache-dir \
    "mlflow<3" \
    "scikit-learn>=1.4" \
    "lightgbm>=4.3" \
    "xgboost>=2.0" \
    "pandas>=2.2" \
    "joblib>=1.4" \
    "httpx>=0.27" \
    "python-dotenv>=1.0" \
    "matplotlib>=3.8" \
    "shap>=0.45"
